echo "NTLM hashes: $(grep -c "NTLM" /opt/mimikatz-lab/output/ntlm_hashes.txt)"

# View sample NTLM hashes
grep -E "(Username|NTLM)" /opt/mimikatz-lab/output/ntlm_hashes.txt | head -10
