Task 1: Configure Kerberos Test Environment
Step 1: Install Kerberos Components
# Install Kerberos client and server tools
sudo apt update
sudo apt install krb5-user krb5-kdc krb5-admin-server -y

# Install Python dependencies
pip3 install pyasn1 pyasn1-modules pycryptodome
Step 2: Configure Kerberos Realm
# Create Kerberos configuration
sudo tee /etc/krb5.conf << 'EOF'
[libdefaults]
    default_realm = TESTLAB.LOCAL
    dns_lookup_realm = false
    dns_lookup_kdc = false
    ticket_lifetime = 24h
    forwardable = true

[realms]
    TESTLAB.LOCAL = {
        kdc = localhost:88
        admin_server = localhost:749
    }

[domain_realm]
    .testlab.local = TESTLAB.LOCAL
    testlab.local = TESTLAB.LOCAL
EOF
Step 3: Initialize Kerberos Database
# Create the Kerberos database (use a strong password when prompted)
sudo kdb5_util create -s -r TESTLAB.LOCAL

# Start Kerberos services
sudo systemctl start krb5-kdc krb5-admin-server
sudo systemctl enable krb5-kdc krb5-admin-server
Step 4: Create Test Principals
# Create test users and services
sudo kadmin.local << 'EOF'
addprinc -pw Password123! testuser@TESTLAB.LOCAL
addprinc -pw Service456! HTTP/webserver.testlab.local@TESTLAB.LOCAL
addprinc -pw Admin789! admin@TESTLAB.LOCAL
exit
EOF
Step 5: Verify Configuration
# Authenticate as test user
echo "Password123!" | kinit testuser@TESTLAB.LOCAL

# List current tickets
klist -v

# Verify ticket cache location
echo "Ticket cache: /tmp/krb5cc_$(id -u)"
