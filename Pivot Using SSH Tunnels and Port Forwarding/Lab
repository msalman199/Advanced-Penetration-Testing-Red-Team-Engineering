Task 2: Implement Dynamic Port Forwarding (SOCKS Proxy)
Step 1: Create SOCKS Proxy Tunnel
# Create dynamic port forwarding (SOCKS5 proxy)
# Syntax: ssh -D [local_port] [user]@[ssh_server]
ssh -f -N -D 1080 pivot_user@localhost

# Verify SOCKS proxy is running
netstat -tlnp | grep 1080
ps aux | grep "ssh.*-D" | grep -v grep
Step 2: Configure ProxyChains
# Install proxychains
sudo apt install -y proxychains4

# Configure proxychains for SOCKS5
sudo tee /etc/proxychains4.conf > /dev/null << 'EOF'
strict_chain
proxy_dns
tcp_read_time_out 15000
tcp_connect_time_out 8000

[ProxyList]
socks5 127.0.0.1 1080
EOF

# Test proxychains with network scan
proxychains4 nc -zv localhost 22
proxychains4 nmap -sT -Pn localhost -p 22,80,8080
