Task 3: Configure Remote Port Forwarding
Step 1: Create Local Service
# Create simple TCP service on port 7777
python3 << 'EOF' &
import socket
server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
server.bind(('127.0.0.1', 7777))
server.listen(5)
print("Service listening on port 7777")
while True:
    conn, addr = server.accept()
    conn.send(b'Hello from local service!\n')
    conn.close()
EOF

# Verify service is running
netstat -tlnp | grep 7777
Step 2: Establish Remote Port Forwarding
# Create remote port forwarding tunnel
# Syntax: ssh -R [remote_port]:[local_host]:[local_port] [user]@[ssh_server]
ssh -f -N -R 8888:localhost:7777 pivot_user@localhost

# Verify tunnel
ps aux | grep "ssh.*-R" | grep -v grep

# Test remote forwarded port
nc localhost 8888
